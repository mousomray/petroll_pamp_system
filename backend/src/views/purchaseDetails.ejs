<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Purchase Invoice - <%= purchase.invoiceNo %>
    </title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #333;
            line-height: 1.6;
            padding: 20px;
            background: #f5f5f5;
        }

        .invoice-container {
            max-width: 900px;
            margin: 0 auto;
            background: white;
            padding: 40px;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.1);
        }

        /* Header Section */
        .invoice-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 40px;
            padding-bottom: 20px;
            border-bottom: 3px solid #2563eb;
        }

        .company-info {
            flex: 1;
        }

        .company-name {
            font-size: 28px;
            font-weight: bold;
            color: #2563eb;
            margin-bottom: 5px;
        }

        .company-tagline {
            font-size: 14px;
            color: #666;
            margin-bottom: 15px;
        }

        .company-details {
            font-size: 12px;
            color: #666;
            line-height: 1.8;
        }

        .invoice-title-section {
            text-align: right;
        }

        .invoice-title {
            font-size: 32px;
            font-weight: bold;
            color: #1e293b;
            margin-bottom: 10px;
        }

        .invoice-number {
            font-size: 16px;
            color: #2563eb;
            font-weight: 600;
            margin-bottom: 10px;
        }

        .invoice-date {
            font-size: 13px;
            color: #666;
        }

        /* Info Section */
        .info-section {
            display: flex;
            justify-content: space-between;
            margin-bottom: 30px;
            gap: 30px;
        }

        .info-box {
            flex: 1;
            padding: 20px;
            border-radius: 8px;
            background: #f8fafc;
            border-left: 4px solid #2563eb;
        }

        .info-box h3 {
            font-size: 14px;
            color: #2563eb;
            margin-bottom: 12px;
            text-transform: uppercase;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .info-box p {
            font-size: 13px;
            color: #333;
            margin-bottom: 5px;
        }

        .info-box strong {
            color: #1e293b;
            font-weight: 600;
        }

        /* Payment Status Badge */
        .payment-status {
            display: inline-block;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            margin-top: 10px;
        }

        .status-paid {
            background: #dcfce7;
            color: #166534;
        }

        .status-partial {
            background: #fef3c7;
            color: #92400e;
        }

        .status-unpaid {
            background: #fee2e2;
            color: #991b1b;
        }

        /* Items Table */
        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
        }

        .items-table thead {
            background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);
            color: white;
        }

        .items-table th {
            padding: 12px 10px;
            text-align: left;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .items-table th:last-child,
        .items-table td:last-child {
            text-align: right;
        }

        .items-table tbody tr {
            border-bottom: 1px solid #e5e7eb;
        }

        .items-table tbody tr:hover {
            background: #f9fafb;
        }

        .items-table td {
            padding: 12px 10px;
            font-size: 13px;
            color: #333;
        }

        .product-name {
            font-weight: 600;
            color: #1e293b;
        }

        .product-info {
            font-size: 11px;
            color: #6b7280;
            margin-top: 2px;
        }

        .tax-breakdown {
            font-size: 11px;
            color: #6b7280;
        }

        /* Summary Section */
        .summary-section {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 30px;
        }

        .summary-box {
            width: 350px;
            border: 2px solid #e5e7eb;
            border-radius: 8px;
            overflow: hidden;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            padding: 12px 20px;
            font-size: 14px;
        }

        .summary-row:not(:last-child) {
            border-bottom: 1px solid #e5e7eb;
        }

        .summary-row.subtotal {
            background: #f9fafb;
        }

        .summary-row.total {
            background: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);
            color: white;
            font-weight: bold;
            font-size: 16px;
        }

        .summary-row.paid {
            background: #dcfce7;
            color: #166534;
            font-weight: 600;
        }

        .summary-row.due {
            background: #fee2e2;
            color: #991b1b;
            font-weight: 600;
        }

        /* Footer */
        .invoice-footer {
            margin-top: 40px;
            padding-top: 20px;
            border-top: 2px solid #e5e7eb;
        }

        .notes-section {
            margin-bottom: 20px;
        }

        .notes-section h4 {
            font-size: 13px;
            color: #2563eb;
            margin-bottom: 8px;
            text-transform: uppercase;
        }

        .notes-section p {
            font-size: 12px;
            color: #666;
            line-height: 1.6;
        }

        .signature-section {
            display: flex;
            justify-content: space-between;
            margin-top: 50px;
        }

        .signature-box {
            text-align: center;
        }

        .signature-line {
            width: 200px;
            border-top: 2px solid #333;
            margin-top: 60px;
            padding-top: 10px;
            font-size: 12px;
            color: #666;
        }

        .footer-text {
            text-align: center;
            font-size: 11px;
            color: #999;
            margin-top: 30px;
        }

        /* Utility Classes */
        .text-right {
            text-align: right;
        }

        .text-center {
            text-align: center;
        }

        .font-bold {
            font-weight: 600;
        }
    </style>
</head>

<body>
    <div class="invoice-container">
        <!-- Header -->
        <div class="invoice-header">
            <div class="company-info">
                <div class="company-name">Petrol Pump Operations</div>
                <div class="company-tagline">Fuel Your Journey</div>
            </div>
            <div class="invoice-title-section">
                <div class="invoice-title">PURCHASE</div>
                <div class="invoice-number">Invoice #<%= purchase.invoiceNo %>
                </div>
                <div class="invoice-date">
                    <strong>Date:</strong>
                    <%= new Date(purchase.purchaseDate).toLocaleDateString('en-IN', { day: '2-digit' , month: 'short' ,
                        year: 'numeric' }) %>
                </div>
            </div>
        </div>

        <!-- Info Section -->
        <div class="info-section">
            <div class="info-box">
                <h3>Supplier Details</h3>
                <p><strong>
                        <%= purchase.supplier?.name || 'N/A' %>
                    </strong></p>
                <% if (purchase.supplier?.address) { %>
                    <p>
                        <%= purchase.supplier.address %>
                    </p>
                    <% } %>
                        <% if (purchase.supplier?.phone) { %>
                            <p><strong>Phone:</strong>
                                <%= purchase.supplier.phone %>
                            </p>
                            <% } %>
                                <% if (purchase.supplier?.email) { %>
                                    <p><strong>Email:</strong>
                                        <%= purchase.supplier.email %>
                                    </p>
                                    <% } %>
                                        <% if (purchase.supplier?.gstin) { %>
                                            <p><strong>GSTIN:</strong>
                                                <%= purchase.supplier.gstin %>
                                            </p>
                                            <% } %>
            </div>

            <div class="info-box">
                <h3>Payment Information</h3>
                <p><strong>Payment Method:</strong>
                    <%= purchase.paymentMethod || 'N/A' %>
                </p>
                <p><strong>Instrument Id:</strong>
                    <%= purchase.instrumentId || 'N/A' %>
                </p>
                <p><strong>Instrument Date:</strong>
                    <%= purchase.instrumentDate ? new Date(purchase.instrumentDate).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) : 'N/A' %>
                </p>
                <p><strong>Payment Status:</strong>
                    <span class="payment-status status-<%= (purchase.paymentStatus || 'UNPAID').toLowerCase() %>">
                        <%= purchase.paymentStatus || 'UNPAID' %>
                    </span>
                </p>
                <% if (purchase.paymentDate) { %>
                    <p><strong>Payment Date:</strong>
                        <%= new Date(purchase.paymentDate).toLocaleDateString('en-IN', { day: '2-digit' , month: 'short'
                            , year: 'numeric' }) %>
                    </p>
                    <% } %>
            </div>
        </div>

        <!-- Items Table -->
        <table class="items-table">
            <thead>
                <tr>
                    <th style="width: 5%;">#</th>
                    <th style="width: 30%;">Product Details</th>
                    <th style="width: 10%;">Quantity</th>
                    <th style="width: 12%;">Unit Price</th>
                    <th style="width: 20%;">Tax</th>
                    <th style="width: 10%;">Tax Amt</th>
                    <th style="width: 13%;">Total</th>
                </tr>
            </thead>
            <tbody>
                <% if (purchase.items && purchase.items.length> 0) { %>
                    <% purchase.items.forEach((item, index)=> { %>
                        <tr>
                            <td>
                                <%= index + 1 %>
                            </td>
                            <td>
                                <div class="product-name">
                                    <%= item.productName || 'N/A' %>
                                </div>
                                <div class="product-info">
                                    <%= item.productType || '' %>
                                        <% if (item.tankName) { %> | Tank: <%= item.tankName %>
                                                <% } %>
                                </div>
                            </td>
                            <td>
                                <%= item.quantity || 0 %>
                                    <%= item.unit || '' %>
                            </td>
                            <td>₹<%= (item.costPrice || 0).toFixed(2) %>
                            </td>
                            <td>
                                <div class="tax-breakdown">
                                    <% if (item.cgstPercent> 0) { %>
                                        CGST: <%= item.cgstPercent %>%<br>
                                            SGST: <%= item.sgstPercent %>%
                                                <% } %>
                                                    <% if (item.igstPercent> 0) { %>
                                                        IGST: <%= item.igstPercent %>%
                                                            <% } %>
                                </div>
                            </td>
                            <td>₹<%= (item.taxAmount || 0).toFixed(2) %>
                            </td>
                            <td class="font-bold">₹<%= (item.total || 0).toFixed(2) %>
                            </td>
                        </tr>
                        <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="7" class="text-center">No items found</td>
                                </tr>
                                <% } %>
            </tbody>
        </table>

        <!-- Summary Section -->
        <div class="summary-section">
            <div class="summary-box">
                <div class="summary-row subtotal">
                    <span>Subtotal</span>
                    <span>₹<%= ((purchase.totalAmount || 0) - (purchase.items?.reduce((sum, item)=> sum +
                            (item.taxAmount || 0), 0) || 0)).toFixed(2) %></span>
                </div>
                <div class="summary-row subtotal">
                    <span>Total Tax</span>
                    <span>₹<%= (purchase.items?.reduce((sum, item)=> sum + (item.taxAmount || 0), 0) || 0).toFixed(2)
                            %></span>
                </div>
                <div class="summary-row total">
                    <span>TOTAL AMOUNT</span>
                    <span>₹<%= (purchase.totalAmount || 0).toFixed(2) %></span>
                </div>
                <div class="summary-row paid">
                    <span>Paid Amount</span>
                    <span>₹<%= (purchase.paidAmount || 0).toFixed(2) %></span>
                </div>
                <% if ((purchase.dueAmount || 0)> 0) { %>
                    <div class="summary-row due">
                        <span>Due Amount</span>
                        <span>₹<%= (purchase.dueAmount || 0).toFixed(2) %></span>
                    </div>
                    <% } %>
            </div>
        </div>

        <!-- Footer -->
        <div class="invoice-footer">
            <% if (purchase.note) { %>
                <div class="notes-section">
                    <h4>Notes</h4>
                    <p>
                        <%= purchase.note %>
                    </p>
                </div>
                <% } %>

                    <div class="signature-section">
                        <div class="signature-box">
                            <div class="signature-line">Authorized Signature</div>
                        </div>
                        <div class="signature-box">
                            <div class="signature-line">Supplier Signature</div>
                        </div>
                    </div>

                    <div class="footer-text">
                        <p>Thank you for your business!</p>
                        <p>Generated on <%= new Date().toLocaleDateString('en-IN', { day: '2-digit' , month: 'short' ,
                                year: 'numeric' , hour: '2-digit' , minute: '2-digit' }) %>
                        </p>
                    </div>
        </div>
    </div>
</body>

</html>